# =====================================================================
# DFS - Avaliação de Desempenho 180º
# Exemplo de variáveis de ambiente (NÃO commitar .env.local)
# =====================================================================

# --- Front-end (Vite + React + MUI) ---------------------------------
# Valores PÚBLICOS — podem ir para o browser.
#
# Onde encontrar:
# Supabase Dashboard → Project Settings → API Keys
#   Project URL          → VITE_SUPABASE_URL
#   Publishable key OU
#   anon public key      → VITE_SUPABASE_ANON_KEY
#
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<cole aqui a publishable key (sb_publishable_...) ou anon key (eyJhbGc...)>

# URL pública do app (usada em links dos e-mails)
VITE_APP_URL=http://localhost:5173
